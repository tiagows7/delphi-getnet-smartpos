<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Getnet SmartPOS DX800"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Teste de Impressão Delphi Android 11"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="@android:color/darker_gray" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Aguardando..."
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@drawable/status_background"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_print_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imprimir Texto"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_print_receipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imprimir Recibo"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_print_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imprimir Imagem"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_print_barcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imprimir Código de Barras"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_print_qrcode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imprimir QR Code"
                android:layout_marginBottom="12dp" />

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/btn_contact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fale Conosco"
        android:layout_marginTop="24dp" />

</LinearLayout>